HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=10s

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pdd_user
POSTGRES_PASSWORD=pdd_password
POSTGRES_DB=pdd_service
POSTGRES_SSL_MODE=disable
POSTGRES_QUERY_TIMEOUT=5s
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONNS=10

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=1m

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/your-bucket
S3_USE_PATH_STYLE=true
S3_PRESIGN_TTL=15m
S3_MAX_VIDEO_SIZE_MB=200

CORS_ALLOWED_ORIGINS=http://localhost:5173
